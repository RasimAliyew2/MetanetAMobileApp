<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MetanetA_MobileApp.ViewModels.ProductsViewModels"
             xmlns:model="clr-namespace:MetanetA_MobileApp.Model"
             xmlns:controls="clr-namespace:MetanetA_MobileApp.View"
             x:Class="MetanetA_MobileApp.View.Products.ProductPage"
             x:DataType="vm:ProductViewModel"
             BackgroundColor="#F2F6F3"
             Title="Məhsullar">

    <ContentPage.Resources>
        <Color x:Key="Primary">#00CE46</Color>
        <Color x:Key="TextDark">#0B1220</Color>
        <Color x:Key="TextGray">#64748B</Color>
        <Color x:Key="Stroke">#E5E7EB</Color>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="Stroke" Value="{StaticResource Stroke}"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 18"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow Opacity="0.10" Radius="14" Offset="0,6"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="SubCatHeader" TargetType="Border">
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="Stroke" Value="{StaticResource Stroke}"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 16"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="ProductCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#FFFFFF"/>
            <Setter Property="Stroke" Value="{StaticResource Stroke}"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 16"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="18"
          RowSpacing="12">

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource SectionHeader}">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
                <Label Text="{Binding SelectedRootCategoryTitle}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextDark}"/>
                <Label Grid.Row="1"
                       Text="Alt kateqoriyanı açıb içindəki məhsulları seçin."
                       FontSize="13"
                       TextColor="{StaticResource TextGray}"/>
            </Grid>
        </Border>

        <!-- SubCategories + Products (accordion) -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding SubCategories}"
                        SelectionMode="None">

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="20" Spacing="6" HorizontalOptions="Center">
                    <Label Text="Kateqoriya seçilməyib"
                           FontAttributes="Bold"
                           FontSize="15"
                           TextColor="{StaticResource TextDark}"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Geri qayıdıb kateqoriya seçin."
                           FontSize="13"
                           TextColor="{StaticResource TextGray}"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ProductSubCategorySection">
                    <VerticalStackLayout Spacing="8" Margin="0,0,0,10">

                        <!-- Subcategory header -->
                        <Border Style="{StaticResource SubCatHeader}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" VerticalOptions="Center">
                                <Label Text="{Binding Name}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextDark}"
                                       VerticalTextAlignment="Center"/>

                                <Label x:Name="Chevron"
                                       Grid.Column="1"
                                       Text="⌄"
                                       FontSize="18"
                                       TextColor="{StaticResource TextGray}"
                                       VerticalTextAlignment="Center"/>

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding BindingContext.ToggleSubCategoryCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding .}"/>
                                </Grid.GestureRecognizers>

                                <Grid.Triggers>
                                    <DataTrigger TargetType="Grid" Binding="{Binding IsExpanded}" Value="True">
                                        <Setter TargetName="Chevron" Property="Label.Rotation" Value="180"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Grid" Binding="{Binding IsExpanded}" Value="False">
                                        <Setter TargetName="Chevron" Property="Label.Rotation" Value="0"/>
                                    </DataTrigger>
                                </Grid.Triggers>

                            </Grid>
                        </Border>

                        <!-- Products list (shown only when expanded) -->
                        <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                             Spacing="10"
                                             Margin="0,0,0,2"
                                             BindableLayout.ItemsSource="{Binding Products}">

                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="model:ProductItem">
                                    <Border Style="{StaticResource ProductCard}">
                                        <Grid ColumnDefinitions="70,*,Auto" ColumnSpacing="10" VerticalOptions="Center">

                                            <Border BackgroundColor="#F6FFF8"
                                                    Stroke="{StaticResource Stroke}"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 14"
                                                    Padding="8">
                                                <Image Source="{Binding ImageUrl}"
                                                       HeightRequest="54"
                                                       WidthRequest="54"
                                                       Aspect="AspectFit"/>
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                <Label Text="{Binding Name}"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource TextDark}"
                                                       LineBreakMode="TailTruncation"/>
                                                <Label Text="{Binding Description}"
                                                       FontSize="12"
                                                       TextColor="{StaticResource TextGray}"
                                                       LineBreakMode="TailTruncation"/>
                                            </VerticalStackLayout>

                                            <Label Grid.Column="2"
                                                   Text="{Binding Price, StringFormat='{0:0.##} ₼'}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="#0F766E"
                                                   VerticalTextAlignment="Center"/>

                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding BindingContext.SelectProductCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>

                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Bottom menu -->
        <controls:BottomMenu Grid.Row="2"
                             VerticalOptions="End"
                             Margin="0,0,0,6"/>
    </Grid>

</ContentPage>
