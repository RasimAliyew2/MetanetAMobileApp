<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MetanetA_MobileApp.View"
             x:Class="MetanetA_MobileApp.View.Sales.CartPage"
             BackgroundColor="#F3F4F6"
             Title="Səbət">

    <!-- 4 sıra: Header / List / Footer button / BottomMenu -->
    <Grid RowDefinitions="Auto,*,Auto,Auto"
          Padding="18"
          RowSpacing="12">

        <!-- Header card -->
        <Border Grid.Row="0"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 18"
                Padding="14">
            <Border.Shadow>
                <Shadow Opacity="0.10" Radius="14" Offset="0,6"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">

                <VerticalStackLayout Spacing="2">
                    <Label Text="Səbət"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#111827"/>
                    <Label Text="{Binding TotalCount, StringFormat='Məhsul sayı: {0}'}"
                           FontSize="12"
                           TextColor="#6B7280"/>
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Təmizlə"
                        Command="{Binding ClearCartCommand}"
                        BackgroundColor="#FEE2E2"
                        TextColor="#991B1B"
                        HeightRequest="36"
                        CornerRadius="14"
                        Padding="14,0"
                        FontAttributes="Bold"/>
            </Grid>
        </Border>

        <!-- Empty label -->
        <Label Grid.Row="1"
               Text="Səbət boşdur."
               IsVisible="{Binding IsEmpty}"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               TextColor="#6B7280"
               FontSize="14"/>

        <!-- Items -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Items}"
                        SelectionMode="None"
                        IsVisible="{Binding IsEmpty, Converter={StaticResource InverseBoolConverter}}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="White"
                            Stroke="#E5E7EB"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            Padding="12"
                            Margin="0,8,0,0">

                        <Grid ColumnDefinitions="64,*,Auto" ColumnSpacing="12">

                            <Image Source="{Binding Item.Image}"
                                   HeightRequest="56"
                                   WidthRequest="56"
                                   Aspect="AspectFit"
                                   VerticalOptions="Center"/>

                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{Binding Item.Name}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#111827"/>

                                <Label Text="{Binding Item.Price, StringFormat='Qiymət: {0} ₼'}"
                                       FontSize="12"
                                       TextColor="#6B7280"/>

                                <Label Text="{Binding LineTotal, StringFormat='Cəm: {0} ₼'}"
                                       FontSize="12"
                                       TextColor="#111827"
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2"
                                                 Spacing="6"
                                                 VerticalOptions="Center">

                                <Button Text="+"
                                        Command="{Binding BindingContext.IncreaseCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#DCFCE7"
                                        TextColor="#166534"
                                        HeightRequest="34"
                                        WidthRequest="40"
                                        CornerRadius="12"
                                        FontAttributes="Bold"/>

                                <Label Text="{Binding Quantity}"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#111827"
                                       FontAttributes="Bold"/>

                                <Button Text="-"
                                        Command="{Binding BindingContext.DecreaseCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#FFE4E6"
                                        TextColor="#9F1239"
                                        HeightRequest="34"
                                        WidthRequest="40"
                                        CornerRadius="12"
                                        FontAttributes="Bold"/>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Footer: Complete order -->
        <Border Grid.Row="2"
        BackgroundColor="White"
        StrokeThickness="0"
        StrokeShape="RoundRectangle 18"
        Padding="12">
            <Border.Shadow>
                <Shadow Opacity="0.08" Radius="12" Offset="0,4"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*,Auto"
          ColumnSpacing="12"
          VerticalOptions="Center">

                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="{Binding TotalPrice, StringFormat='Ümumi: {0} ₼'}"
                   FontSize="14"
                   FontAttributes="Bold"
                   TextColor="#111827"/>

                    <Label Text="Sifarişi təsdiqləmək üçün tamamla."
                   FontSize="12"
                   TextColor="#6B7280"/>
                </VerticalStackLayout>

                <Button Grid.Column="1"
                Text="Sifarişi tamamla"
                Command="{Binding CompleteOrderCommand}"
                BackgroundColor="#00CE46"
                TextColor="White"
                HeightRequest="46"
                CornerRadius="16"
                Padding="18,0"
                FontAttributes="Bold"
                FontSize="14"
                HorizontalOptions="End"
                MinimumWidthRequest="170"
                IsEnabled="{Binding IsEmpty, Converter={StaticResource InverseBoolConverter}}">
                    <Button.VisualStateManager.VisualStateGroups>
                        <VisualStateGroupList>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Property="Opacity" Value="0.75"/>
                                        <Setter Property="Scale" Value="0.98"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Property="Opacity" Value="0.45"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateGroupList>
                    </Button.VisualStateManager.VisualStateGroups>
                </Button>

            </Grid>
        </Border>

        <!-- Bottom menu -->
        <controls:BottomMenu Grid.Row="3"
                             VerticalOptions="End"
                             Margin="0,0,0,6"/>

        <!-- ✅ Big popup overlay -->
        <Grid Grid.Row="0"
              Grid.RowSpan="4"
              IsVisible="{Binding IsOrderPopupVisible}"
              BackgroundColor="#80000000">

            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 22"
                    Padding="18"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="320">

                <Border.Shadow>
                    <Shadow Opacity="0.20" Radius="22" Offset="0,10"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="12" HorizontalOptions="Fill">

                    <Label Text="Sifarişiniz qeydə alındı"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           HorizontalTextAlignment="Center"/>

                    <Label Text="Tezliklə sizinlə əlaqə saxlanılacaq."
                           FontSize="13"
                           TextColor="#6B7280"
                           HorizontalTextAlignment="Center"/>

                    <Button Text="Təşəkkür edirəm"
                            Command="{Binding DismissOrderPopupCommand}"
                            BackgroundColor="#00CE46"
                            TextColor="White"
                            HeightRequest="46"
                            CornerRadius="16"
                            FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
