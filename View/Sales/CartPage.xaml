<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MetanetA_MobileApp.View"
             x:Class="MetanetA_MobileApp.View.Sales.CartPage"
             BackgroundColor="#F3F4F6"
             Title="Səbət">

    <ContentPage.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#00CE46"/>
            <Setter Property="TextColor" Value="White"/>
            <Setter Property="HeightRequest" Value="46"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal"/>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Opacity" Value="0.75"/>
                                <Setter Property="Scale" Value="0.98"/>
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Disabled">
                            <VisualState.Setters>
                                <Setter Property="Opacity" Value="0.55"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#E5E7EB"/>
            <Setter Property="TextColor" Value="#111827"/>
            <Setter Property="HeightRequest" Value="46"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="FontAttributes" Value="Bold"/>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto,Auto" Padding="18" RowSpacing="12">

        <!-- Header card -->
        <Border BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 18"
                Padding="14">
            <Border.Shadow>
                <Shadow Opacity="0.10" Radius="14" Offset="0,6"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">

                <VerticalStackLayout Spacing="2">
                    <Label Text="Səbət"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#111827"/>
                    <Label Text="{Binding TotalCount, StringFormat='Məhsul sayı: {0}'}"
                           FontSize="12"
                           TextColor="#6B7280"/>
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Təmizlə"
                        Command="{Binding ClearCartCommand}"
                        BackgroundColor="#FEE2E2"
                        TextColor="#991B1B"
                        HeightRequest="36"
                        CornerRadius="14"
                        Padding="14,0"
                        FontAttributes="Bold"/>
            </Grid>
        </Border>

        <!-- Empty label -->
        <Label Grid.Row="1"
               Text="Səbət boşdur."
               IsVisible="{Binding IsEmpty}"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               TextColor="#6B7280"
               FontSize="14"/>

        <!-- Items -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Items}"
                        SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="White"
                            Stroke="#E5E7EB"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            Padding="12"
                            Margin="0,8,0,0">

                        <Grid ColumnDefinitions="64,*,Auto" ColumnSpacing="12">

                            <Image Source="{Binding Item.Image}"
                                   HeightRequest="56"
                                   WidthRequest="56"
                                   Aspect="AspectFit"
                                   VerticalOptions="Center"/>

                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{Binding Item.Name}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#111827"/>

                                <Label Text="{Binding Item.Price, StringFormat='Qiymət: {0} ₼'}"
                                       FontSize="12"
                                       TextColor="#6B7280"/>

                                <Label Text="{Binding LineTotal, StringFormat='Cəm: {0} ₼'}"
                                       FontSize="12"
                                       TextColor="#111827"
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2"
                                                 Spacing="6"
                                                 VerticalOptions="Center">

                                <Button Text="+"
                                        Command="{Binding BindingContext.IncreaseCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#DCFCE7"
                                        TextColor="#166534"
                                        HeightRequest="34"
                                        WidthRequest="40"
                                        CornerRadius="12"
                                        FontAttributes="Bold"/>

                                <Label Text="{Binding Quantity}"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#111827"
                                       FontAttributes="Bold"/>

                                <Button Text="-"
                                        Command="{Binding BindingContext.DecreaseCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#FFE4E6"
                                        TextColor="#9F1239"
                                        HeightRequest="34"
                                        WidthRequest="40"
                                        CornerRadius="12"
                                        FontAttributes="Bold"/>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Footer: Complete order -->
        <Border Grid.Row="2"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 18"
                Padding="12">
            <Border.Shadow>
                <Shadow Opacity="0.08" Radius="12" Offset="0,4"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12"
                  VerticalOptions="Center">

                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="{Binding TotalPrice, StringFormat='Ümumi: {0} ₼'}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#111827"/>

                    <Label Text="Sifarişi təsdiqləmək üçün tamamla."
                           FontSize="12"
                           TextColor="#6B7280"/>
                </VerticalStackLayout>

                <Button Text="Sifarişi tamamla"
                        Grid.Column="1"
                        Style="{StaticResource PrimaryBtn}"
                        IsEnabled="{Binding HasItems}"
                        Command="{Binding CompleteOrderCommand}"/>
            </Grid>
        </Border>

        <!-- Bottom menu -->
        <controls:BottomMenu Grid.Row="3"
                             VerticalOptions="End"
                             Margin="0,0,0,6"/>

        <!-- ✅ POPUP OVERLAY (ən sonda olmalıdır) -->
        <Grid IsVisible="{Binding IsOrderPopupVisible}"
              Grid.RowSpan="4"
              BackgroundColor="#80000000"
              Padding="24">

            <!-- Çöldə basanda da bağlansın -->
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding DismissOrderPopupCommand}" />
            </Grid.GestureRecognizers>

            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 22"
                    Padding="18"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="320">
                <Border.Shadow>
                    <Shadow Opacity="0.18" Radius="18" Offset="0,10"/>
                </Border.Shadow>

                <!-- İçəridə tap overlay-i bağlamasın -->
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding DismissOrderPopupCommand}" NumberOfTapsRequired="2"/>
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="12">
                    <Label Text="Sifarişiniz qeydə alındı"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           HorizontalTextAlignment="Center"/>

                    <Label Text="Sifarişiniz üçün təşəkkür edirik."
                           FontSize="13"
                           TextColor="#6B7280"
                           HorizontalTextAlignment="Center"/>

                    <Button Text="Təşəkkür edirəm"
                            Style="{StaticResource PrimaryBtn}"
                            Command="{Binding DismissOrderPopupCommand}"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
