<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MetanetA_MobileApp.View.SignInPage"
             BackgroundColor="#F3F4F6">

    <ContentPage.Resources>
        <!-- Eye icon style -->
        <Style x:Key="EyeButtonStyle" TargetType="ImageButton">
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="WidthRequest" Value="28"/>
            <Setter Property="HeightRequest" Value="28"/>
            <Setter Property="HorizontalOptions" Value="End"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="Opacity" Value="0.8"/>
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal"/>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Opacity" Value="0.55"/>
                                <Setter Property="Scale" Value="0.92"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <Grid Padding="18">

        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout VerticalOptions="Center"
                                 Spacing="14"
                                 Padding="0,18">

                <!-- Logo -->
                <Image Source="matanat_logo.png"
                       HeightRequest="86"
                       HorizontalOptions="Center"
                       Margin="0,10,0,0"/>

                <!-- Card -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 18"
                        Padding="16">
                    <Border.Shadow>
                        <Shadow Opacity="0.15" Radius="18" Offset="0,8" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="12">

                        <Label Text="Daxil ol"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label Text="Hesab məlumatlarınızı daxil edin."
                               FontSize="13"
                               TextColor="#6B7280" />

                        <!-- Phone -->
                        <Label Text="Telefon nömrəsi"
                               FontSize="13"
                               TextColor="#6B7280"
                               Margin="2,8,0,0"/>

                        <Border Stroke="#E5E7EB"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <Entry Placeholder="994XXXXXXXXX"
                                   Keyboard="Numeric"
                                   Text="{Binding PhoneNumber}"
                                   FontSize="14"
                                   TextColor="#111827"
                                   PlaceholderColor="#9CA3AF"
                                   BackgroundColor="Transparent" />
                        </Border>

                        <!-- Password -->
                        <Label Text="Parol"
                               FontSize="13"
                               TextColor="#6B7280"
                               Margin="2,6,0,0"/>

                        <Border Stroke="#E5E7EB"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">

                            <!-- Entry + Eye -->
                            <Grid ColumnDefinitions="*,34" ColumnSpacing="8">
                                <Entry Grid.Column="0"
                                       Placeholder="Parol"
                                       IsPassword="{Binding IsPasswordHidden}"
                                       Text="{Binding Password}"
                                       FontSize="14"
                                       TextColor="#111827"
                                       PlaceholderColor="#9CA3AF"
                                       BackgroundColor="Transparent" />

                                <ImageButton Grid.Column="1"
                                             Source="eye_icon.png"
                                             Style="{StaticResource EyeButtonStyle}"
                                             Command="{Binding TogglePasswordVisibilityCommand}">
                                    <ImageButton.Triggers>
                                        <DataTrigger TargetType="ImageButton"
                                                     Binding="{Binding IsPasswordHidden}"
                                                     Value="False">
                                            <Setter Property="Source" Value="closed_eye_icon.png" />
                                        </DataTrigger>
                                    </ImageButton.Triggers>
                                </ImageButton>
                            </Grid>

                        </Border>

                        <!-- Errors -->
                        <Border IsVisible="{Binding InvalidCredentials}"
                                BackgroundColor="#FEF2F2"
                                Stroke="#FCA5A5"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <Label Text="Nömrə və ya parol səhvdir."
                                   TextColor="#B91C1C"
                                   FontSize="13"/>
                        </Border>

                        <Border IsVisible="{Binding FillTheArea}"
                                BackgroundColor="#FFFBEB"
                                Stroke="#FCD34D"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <Label Text="Zəhmət olmasa gərəkli xanaları doldurun."
                                   TextColor="#92400E"
                                   FontSize="13"/>
                        </Border>

                        <!-- Forgot password -->
                        <Label Text="Şifrəmi unutdum"
                               TextColor="#2563EB"
                               FontSize="13"
                               FontAttributes="Bold"
                               HorizontalOptions="Start"
                               Margin="2,2,0,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="ForgotPassword_Tapped" />
                            </Label.GestureRecognizers>
                        </Label>

                        <!-- Buttons -->
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12"
                              Margin="0,8,0,0">

                            <Button Text="Daxil ol"
                                    Command="{Binding SignInCommand}"
                                    BackgroundColor="#16A34A"
                                    TextColor="White"
                                    HeightRequest="50"
                                    CornerRadius="16"
                                    FontAttributes="Bold" />

                            <Button Grid.Column="1"
                                    Text="Qeydiyyat"
                                    Command="{Binding SignUpCommand}"
                                    BackgroundColor="#E5E7EB"
                                    TextColor="#111827"
                                    HeightRequest="50"
                                    CornerRadius="16"
                                    FontAttributes="Bold" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
