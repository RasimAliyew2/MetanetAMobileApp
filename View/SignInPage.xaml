<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MetanetA_MobileApp.View.SignInPage">


    <Grid RowDefinitions="Auto,*" VerticalOptions="Center" Padding="10" Margin="0,0,0,200">

    <Image Source="matanat_logo.png" 
           Grid.Row="0"
           Margin="50"/>
       
    <VerticalStackLayout  Grid.Row="1">
      <Label
      Text="İstifadəçi adı" FontSize="14"
      Margin="10,0,0,0"
      HorizontalOptions="Start"
      VerticalOptions="Center"
      HorizontalTextAlignment="Center"
      VerticalTextAlignment="Center"/>


            <Border Stroke="#DDDDDD"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 10"
            Margin="0,4">
            <Entry Placeholder="Telefon nömrəsi"
                   BackgroundColor="White"
                   Style="{StaticResource NiceEntry}" 
                   Text="{Binding UserInfo.PhoneNumber}"/>
            </Border>
            <Label
      Text="Parol" FontSize="14" Margin="10,0,0,0"
      HorizontalOptions="Start"
      VerticalOptions="Center"
      HorizontalTextAlignment="Center"
      VerticalTextAlignment="Center"/>

        

            <Border Stroke="#DDDDDD"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 10"
            Margin="0,4">
              <Entry Placeholder="parol"
                     BackgroundColor="White"
                Style="{StaticResource NiceEntry}" 
                
                Text="{Binding UserInfo.Password}"/>
            </Border>

            <Grid ColumnDefinitions="*,*">
                <Button 
                   BackgroundColor="ForestGreen"
                   TextColor="Black"
                   Text="Daxil ol" 
                   Margin="5"
                   Command="{Binding SignInCommand}"/>

            <Button Text="Qediyyat"
                   BackgroundColor="ForestGreen"
                   TextColor="Black"
                   Grid.Column="1"
                   Margin="5"
                   Command="{Binding SignUpCommand}"/>

        </Grid>
    </VerticalStackLayout>
    </Grid>
</ContentPage>