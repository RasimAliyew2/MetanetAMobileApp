<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MetanetA_MobileApp.View"
    x:Class="MetanetA_MobileApp.View.VideosPage"
    BackgroundColor="#F3F4F6"
    Title="Videolar">

    <Grid Padding="18"
          RowDefinitions="Auto,Auto,Auto,*,Auto"
          RowSpacing="12">

        <!-- Title -->
        <Label Grid.Row="0"
               Text="Təlim videoları"
               FontSize="22"
               FontAttributes="Bold"
               TextColor="#111827" />

        <!-- Subtitle -->
        <Label Grid.Row="1"
               Text="Siyahıdan videonu seçin."
               FontSize="13"
               TextColor="#6B7280" />

        <!-- Search -->
        <Border Grid.Row="2"
                BackgroundColor="White"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="10,0"
                HeightRequest="44">

            <SearchBar Placeholder="Axtarış... (Title və ya izah)"
                       Text="{Binding SearchText}"
                       BackgroundColor="Transparent"
                       HeightRequest="44"
                       FontSize="14"
                       TextColor="#111827"
                       PlaceholderColor="#9CA3AF"
                       CancelButtonColor="#6B7280" />
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="3"
              RowDefinitions="Auto,Auto,*"
              RowSpacing="12">

            <!-- Player -->
            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 18"
                    Padding="0">
                <Border.Shadow>
                    <Shadow Opacity="0.12" Radius="16" Offset="0,6"/>
                </Border.Shadow>

                <Grid>
                    <WebView Source="{Binding PlayerSource}"
                             HeightRequest="220" />

                    <!-- heç nə seçilməyibsə overlay mesaj -->
                    <Grid IsVisible="{Binding ShowSelectHint}">
                        <Label Text="Video seçilməyib"
                               TextColor="#6B7280"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Open in YouTube -->
            <Button Grid.Row="1"
                    Text="YouTube-da aç"
                    Command="{Binding OpenInYouTubeCommand}"
                    BackgroundColor="#E5E7EB"
                    TextColor="#111827"
                    HeightRequest="46"
                    CornerRadius="14"
                    FontAttributes="Bold" />

            <!-- No results -->
            <Border Grid.Row="2"
                    IsVisible="{Binding ShowNoResults}"
                    BackgroundColor="#FFFBEB"
                    Stroke="#FCD34D"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 14"
                    Padding="12,10"
                    Margin="0,8,0,0">
                <Label Text="Axtarışa uyğun video tapılmadı."
                       TextColor="#92400E"
                       FontSize="13" />
            </Border>

            <!-- List -->
            <CollectionView Grid.Row="2"
                            ItemsSource="{Binding FilteredVideos}"
                            SelectedItem="{Binding SelectedVideo, Mode=TwoWay}"
                            SelectionMode="Single"
                            Margin="0,44,0,0">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White"
                                Stroke="#E5E7EB"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16"
                                Padding="12"
                                Margin="0,8,0,0">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">

                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Title}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#111827"/>

                                    <Label Text="{Binding Description}"
                                           FontSize="12"
                                           TextColor="#6B7280"
                                           LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>

                                <Label Grid.Column="1"
                                       Text="▶"
                                       FontSize="18"
                                       TextColor="#16A34A"
                                       VerticalTextAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

        <!-- Bottom menu -->
        <controls:BottomMenu Grid.Row="4"
                             VerticalOptions="End"
                             Margin="0,0,0,6"/>
    </Grid>
</ContentPage>
