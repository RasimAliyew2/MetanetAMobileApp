<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MetanetA_MobileApp.View.RequestAcceptedPage"
             Title="">

    <Grid Padding="24">
        <VerticalStackLayout
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Spacing="18">

            <!-- Böyük yaşıl quş (Material Icon: "bird") -->
            <Image
                WidthRequest="140"
                HeightRequest="140"
                Source="mail">
                
            </Image>

            <Label
                Text="Müraciətiniz qəbul olundu, qısa zamanda geri dönüş alacaqsınız"
                HorizontalTextAlignment="Center"
                FontSize="18"
                TextColor="#111827" />

            <Button
                Text="Təşəkkürlər"
                CornerRadius="14"
                HeightRequest="48"
                Padding="18,0"
                BackgroundColor="#16A34A"
                TextColor="White"
                HorizontalOptions="Center"
                Command="{Binding GoToSignInPageCommand}"/>

        </VerticalStackLayout>
    </Grid>
</ContentPage>