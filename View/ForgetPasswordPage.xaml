<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MetanetA_MobileApp.View.ForgetPasswordPage"
             Title="">

    <Grid RowDefinitions="Auto,*,Auto,*"
          
          
          VerticalOptions="Center"
          HorizontalOptions="Center">

        <Label Text="Telefon nömrənizi qeyd edin"/>

     
        <Border Stroke="#DDDDDD"
                Grid.Row="1"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 10"
                Margin="0,4">

            <Entry Placeholder="Telefon nömrəsi"
                   BackgroundColor="White"
                   Style="{StaticResource NiceEntry}" 
                   Text="{Binding PhoneNumber}"
                   Keyboard="Numeric"
                   />
        </Border>

        <Label Text="Telefon nömrəsi tapılmadı !"
               TextColor="Red"
               Grid.Row="2"
               Margin="5"
               IsVisible="{Binding PhoneNotNumberNotFound}"/>

        <Button Text="Təsdiqlə"
                Grid.Row="3"
                Command="{Binding ApproveTheNumberCommand}"/>
    </Grid>
</ContentPage>