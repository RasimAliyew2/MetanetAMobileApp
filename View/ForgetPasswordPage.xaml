<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MetanetA_MobileApp.View.ForgetPasswordPage"
             BackgroundColor="#F3F4F6"
             Title="">

    <ContentPage.Resources>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="StrokeThickness" Value="0"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 18"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow Opacity="0.15" Radius="18" Offset="0,8"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldBorder" TargetType="Border">
            <Setter Property="Stroke" Value="#E5E7EB"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="BackgroundColor" Value="#F9FAFB"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 14"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#16A34A"/>
            <Setter Property="TextColor" Value="White"/>
            <Setter Property="HeightRequest" Value="52"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

    </ContentPage.Resources>

    <Grid Padding="18">
        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout VerticalOptions="Center"
                                 Spacing="14"
                                 Padding="0,18">

                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="Şifrəni unutmusunuz?"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               HorizontalTextAlignment="Center" />

                        <Label Text="Telefon nömrənizi daxil edin. Nömrə tapılarsa sizə təsdiq kodu göndərəcəyik."
                               FontSize="13"
                               TextColor="#6B7280"
                               HorizontalTextAlignment="Center" />

                        <!-- Phone -->
                        <Label Text="Telefon nömrəsi"
                               FontSize="13"
                               TextColor="#6B7280"
                               Margin="2,8,0,0"/>

                        <Border Style="{StaticResource FieldBorder}">
                            <Entry Placeholder="994XXXXXXXXX"
                                   Keyboard="Numeric"
                                   Text="{Binding PhoneNumber}"
                                   FontSize="14"
                                   TextColor="#111827"
                                   PlaceholderColor="#9CA3AF"
                                   BackgroundColor="Transparent" />
                        </Border>

                        <!-- Error -->
                        <Border IsVisible="{Binding PhoneNotNumberNotFound}"
                                BackgroundColor="#FEF2F2"
                                Stroke="#FCA5A5"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <Label Text="Telefon nömrəsi tapılmadı!"
                                   TextColor="#B91C1C"
                                   FontSize="13"/>
                        </Border>

                        <!-- Button -->
                        <Button Text="Təsdiqlə"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ApproveTheNumberCommand}"
                                Margin="0,6,0,0"/>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
