<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MetanetA_MobileApp.View.Sign.SetPasswordPage"
               Title="">

    <VerticalStackLayout Padding="24" Spacing="12" VerticalOptions="Center">

        <Label Text="Parolunuzu daxil edin"/>
        <Entry Placeholder="Parol"
               IsPassword="True"
               Text="{Binding Password}" />

        <VerticalStackLayout Spacing="6">
            <Entry Placeholder="Təkrar parol"
                   IsPassword="True"
                   Text="{Binding ConfirmPassword}" />

            <Label Text="{Binding MismatchText}"
                   TextColor="Red"
                   FontSize="12"
                   IsVisible="{Binding IsMismatch}" />
        </VerticalStackLayout>

        <Button Text="Təsdiq et"
                BackgroundColor="ForestGreen"
                TextColor="White"
                Command="{Binding ConfirmCommand}"
                Margin="0,10,0,0"/>
    </VerticalStackLayout>
</ContentPage>