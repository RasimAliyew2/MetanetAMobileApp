<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MetanetA_MobileApp.View.Sign.SetPasswordPage"
             BackgroundColor="#F3F4F6"
             Title="">

    <ContentPage.Resources>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="StrokeThickness" Value="0"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 18"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow Opacity="0.15" Radius="18" Offset="0,8"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldBorder" TargetType="Border">
            <Setter Property="Stroke" Value="#E5E7EB"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="BackgroundColor" Value="#F9FAFB"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 14"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#16A34A"/>
            <Setter Property="TextColor" Value="White"/>
            <Setter Property="HeightRequest" Value="52"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <!-- Eye icon button style -->
        <Style x:Key="EyeButtonStyle" TargetType="ImageButton">
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="WidthRequest" Value="28"/>
            <Setter Property="HeightRequest" Value="28"/>
            <Setter Property="HorizontalOptions" Value="End"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="Opacity" Value="0.8"/>
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal"/>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Opacity" Value="0.55"/>
                                <Setter Property="Scale" Value="0.92"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>

    </ContentPage.Resources>

    <Grid Padding="18">
        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout VerticalOptions="Center" Spacing="14" Padding="0,18">

                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="Parol təyin edin"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               HorizontalTextAlignment="Center"/>

                        <Label Text="Parol minimum 8 simvol və ən azı 1 böyük hərf (A-Z) içərməlidir."
                               FontSize="13"
                               TextColor="#6B7280"
                               HorizontalTextAlignment="Center"/>

                        <!-- Password -->
                        <Label Text="Parol"
                               FontSize="13"
                               TextColor="#6B7280"
                               Margin="2,8,0,0"/>

                        <Border Style="{StaticResource FieldBorder}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsPasswordRuleInvalid}"
                                             Value="True">
                                    <Setter Property="Stroke" Value="#EF4444"/>
                                    <Setter Property="BackgroundColor" Value="#FEF2F2"/>
                                </DataTrigger>
                            </Border.Triggers>

                            <Grid ColumnDefinitions="*,34" ColumnSpacing="8">
                                <Entry Grid.Column="0"
                                       Placeholder="Parol"
                                       IsPassword="{Binding IsPasswordHidden}"
                                       Text="{Binding Password}"
                                       BackgroundColor="Transparent"
                                       TextColor="#111827"
                                       PlaceholderColor="#9CA3AF"
                                       FontSize="14" />

                                <ImageButton Grid.Column="1"
                                             Source="eye_icon.png"
                                             Style="{StaticResource EyeButtonStyle}"
                                             Command="{Binding TogglePasswordVisibilityCommand}">
                                    <ImageButton.Triggers>
                                        <DataTrigger TargetType="ImageButton"
                                                 Binding="{Binding IsPasswordHidden}"
                                                 Value="False">
                                            <Setter Property="Source" Value="closed_eye_icon.png" />
                                        </DataTrigger>
                                    </ImageButton.Triggers>
                                </ImageButton>
                            </Grid>
                        </Border>

                        <!-- Password rule message -->
                        <Border IsVisible="{Binding IsPasswordRuleInvalid}"
                                BackgroundColor="#FEF2F2"
                                Stroke="#FCA5A5"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <Label Text="{Binding PasswordRuleText}"
                                   TextColor="#B91C1C"
                                   FontSize="13"/>
                        </Border>

                        <!-- Confirm Password -->
                        <Label Text="Təkrar parol"
                               FontSize="13"
                               TextColor="#6B7280"
                               Margin="2,6,0,0"/>

                        <Border Style="{StaticResource FieldBorder}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsMismatch}"
                                             Value="True">
                                    <Setter Property="Stroke" Value="#EF4444"/>
                                    <Setter Property="BackgroundColor" Value="#FEF2F2"/>
                                </DataTrigger>
                            </Border.Triggers>

                            <Grid ColumnDefinitions="*,34" ColumnSpacing="8">

                                <Entry Grid.Column="0"
                                       Placeholder="Təkrar parol"
                                       IsPassword="{Binding IsConfirmPasswordHidden}"
                                       Text="{Binding ConfirmPassword}"
                                       BackgroundColor="Transparent"
                                       TextColor="#111827"
                                       PlaceholderColor="#9CA3AF"
                                       FontSize="14" />

                                <ImageButton Grid.Column="1"
                                             Source="eye_icon.png"
                                             Style="{StaticResource EyeButtonStyle}"
                                             Command="{Binding ToggleConfirmPasswordVisibilityCommand}">
                                    <ImageButton.Triggers>
                                        <DataTrigger TargetType="ImageButton"
                                                     Binding="{Binding IsPasswordHidden}"
                                                     Value="False">
                                            <Setter  Property="Source" Value="closed_eye_icon.png" />
                                        </DataTrigger>
                                   </ImageButton.Triggers>
                                </ImageButton>
                            </Grid>
                        </Border>

                        <!-- Mismatch -->
                        <Border IsVisible="{Binding IsMismatch}"
                                BackgroundColor="#FEF2F2"
                                Stroke="#FCA5A5"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10">
                            <Label Text="{Binding MismatchText}"
                                   TextColor="#B91C1C"
                                   FontSize="13"/>
                        </Border>

                        <!-- Button -->
                        <Button Text="Təsdiq et"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ConfirmCommand}"
                                Margin="0,6,0,0"/>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
