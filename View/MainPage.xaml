<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:model="clr-namespace:MetanetA_MobileApp.Model"
    xmlns:ViewModel="clr-namespace:MetanetA_MobileApp.ViewModels"
    xmlns:controls="clr-namespace:MetanetA_MobileApp.View"
    x:DataType="ViewModel:MainViewModel"
    x:Class="MetanetA_MobileApp.View.MainPage"
    BackgroundColor="#F3F4F6">

    <ContentPage.Resources>

        <!-- Colors -->
        <Color x:Key="TextDark">#111827</Color>
        <Color x:Key="TextGray">#6B7280</Color>
        <Color x:Key="BorderGray">#E5E7EB</Color>
        <Color x:Key="BgSoft">#F3F4F6</Color>
        <Color x:Key="PrimaryGreen">#16A34A</Color>

        <!-- Top card -->
        <Style x:Key="TopCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="StrokeThickness" Value="0"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 22"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow Opacity="0.12" Radius="18" Offset="0,8" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search container -->
        <Style x:Key="SearchContainer" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#F9FAFB"/>
            <Setter Property="Stroke" Value="{StaticResource BorderGray}"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 18"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HeightRequest" Value="44"/>
        </Style>

        <!-- Suggestions container -->
        <Style x:Key="SuggestCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="Stroke" Value="{StaticResource BorderGray}"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 18"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <!-- Top icon -->
        <Style x:Key="TopIconStyle" TargetType="ImageButton">
            <Setter Property="WidthRequest" Value="40"/>
            <Setter Property="HeightRequest" Value="40"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="BackgroundColor" Value="#F3F4F6"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal"/>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Opacity" Value="0.65"/>
                                <Setter Property="Scale" Value="0.95"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>

        <!-- Transparent tile button (text overlay) -->
        <Style x:Key="TileOverlayButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="TextColor" Value="White"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="HeightRequest" Value="118"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="HorizontalOptions" Value="Fill"/>
            <Setter Property="VerticalOptions" Value="Fill"/>
            <Setter Property="TextTransform" Value="None"/>
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal"/>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Opacity" Value="1"/>
                                <Setter Property="Scale" Value="1"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>

        <!-- Promo overlay button (BasedOn MUST come after TileOverlayButton) -->
        <Style x:Key="PromoOverlayButton" TargetType="Button" BasedOn="{StaticResource TileOverlayButton}">
            <Setter Property="HeightRequest" Value="158"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <!-- Tile card -->
        <Style x:Key="TileCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="StrokeThickness" Value="0"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 18"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow Opacity="0.10" Radius="14" Offset="0,6"/>
                </Setter.Value>
            </Setter>
        </Style>

    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="18"
          RowSpacing="14">

        <!-- TOP BAR -->
        <Border Grid.Row="0" Style="{StaticResource TopCard}">

            <Grid RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="12">

                <!-- Row 0: Logo + icons -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="10"
                      VerticalOptions="Center">

                    <Image Source="masters_club_icon.png"
                           WidthRequest="180"
                           HeightRequest="40"
                           Aspect="AspectFit"
                           VerticalOptions="Center"/>

                    <!-- Basket + Badge -->
                    <Grid Grid.Column="1" WidthRequest="40" HeightRequest="40" Margin="10">
                        <ImageButton Source="basket.png"
                                     Style="{StaticResource TopIconStyle}"
                                     Command="{Binding OpenCartCommand}" />

                        <Border BackgroundColor="#EF4444"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 999"
                                HorizontalOptions="End"
                                VerticalOptions="Start"
                                Margin="0,-6,-6,0"
                                WidthRequest="18"
                                HeightRequest="18">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding CartService.TotalCount}"
                                             Value="0">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Label Text="{Binding CartService.TotalCount}"
                                   FontSize="10"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"/>
                        </Border>
                    </Grid>

                    <ImageButton Grid.Column="2"
                                 Source="noticifation_button.png"
                                 Style="{StaticResource TopIconStyle}" />
                </Grid>

                <!-- Row 1: Search -->
                <Border Grid.Row="1" Style="{StaticResource SearchContainer}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" VerticalOptions="Center">
                        <SearchBar Placeholder="Məhsul axtar..."
                                   HeightRequest="44"
                                   BackgroundColor="Transparent"
                                   CancelButtonColor="{StaticResource TextGray}"
                                   TextColor="{StaticResource TextDark}"
                                   PlaceholderColor="#9CA3AF"
                                   Text="{Binding SearchText}" />

                        <ImageButton Grid.Column="1"
                                     Source="close_icon.png"
                                     BackgroundColor="Transparent"
                                     WidthRequest="28"
                                     HeightRequest="28"
                                     Command="{Binding ClearMainSearchCommand}"
                                     Opacity="0.70"
                                     Padding="0">
                            <ImageButton.Triggers>
                                <DataTrigger TargetType="ImageButton" Binding="{Binding SearchText}" Value="">
                                    <Setter Property="IsVisible" Value="False"/>
                                </DataTrigger>
                                <DataTrigger TargetType="ImageButton" Binding="{Binding SearchText}" Value="{x:Null}">
                                    <Setter Property="IsVisible" Value="False"/>
                                </DataTrigger>
                            </ImageButton.Triggers>
                        </ImageButton>
                    </Grid>
                </Border>

                <!-- Row 2: Suggestions -->
                <Border Grid.Row="2"
                        Style="{StaticResource SuggestCard}"
                        IsVisible="{Binding IsSearchResultsVisible}"
                        Padding="0">
                    <CollectionView ItemsSource="{Binding SearchResults}"
                                    HeightRequest="260"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:SalesItem">
                                <Border Stroke="#F3F4F6"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 14"
                                        Padding="10"
                                        Margin="10,8,10,0"
                                        BackgroundColor="White">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.OpenSuggestedProductCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="10">
                                        <Border BackgroundColor="#F9FAFB"
                                                Stroke="#E5E7EB"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 12"
                                                Padding="6"
                                                WidthRequest="52"
                                                HeightRequest="52">
                                            <Image Source="{Binding Image}" Aspect="AspectFit"/>
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="#111827"
                                                   LineBreakMode="TailTruncation"/>
                                            <Label Text="Məhsul"
                                                   FontSize="12"
                                                   TextColor="#6B7280"/>
                                        </VerticalStackLayout>

                                        <Label Grid.Column="2"
                                               Text="{Binding Price, StringFormat='{0:0.##} ₼'}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="#0F766E"
                                               VerticalTextAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>

            </Grid>

        </Border>

        <!-- CONTENT -->
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Always">
            <VerticalStackLayout Spacing="14">

                <!-- Quick actions 2x2 -->
                <Grid ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="12"
                      RowSpacing="12">

                    <!-- Alış-veriş -->
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource TileCard}">
                        <Grid>
                            <Image Source="sales"
                                   Aspect="AspectFill"
                                   InputTransparent="True"/>
                            <Button Style="{StaticResource TileOverlayButton}"
                                    Command="{Binding ShopCommand}" />
                        </Grid>
                    </Border>

                    <!-- Bonus -->
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource TileCard}">
                        <Grid>
                            <Image Source="bonuses"
                                   Aspect="AspectFill"
                                   InputTransparent="True"/>
                            <Button Style="{StaticResource TileOverlayButton}"
                                    Command="{Binding GoTobonusPageCommand}" />
                        </Grid>
                    </Border>

                    <!-- Hədiyyələr -->
                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource TileCard}">
                        <Grid>
                            <Image Source="gifts"
                                   Aspect="AspectFill"
                                   InputTransparent="True"/>
                            <Button Style="{StaticResource TileOverlayButton}"
                                    Command="{Binding GiftsCommand}" />
                        </Grid>
                    </Border>

                    <!-- Təlim -->
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource TileCard}">
                        <Grid>
                            <Image Source="tutorial"
                                   Aspect="AspectFill"
                                   InputTransparent="True"/>
                            <Button Style="{StaticResource TileOverlayButton}"
                                    Command="{Binding TrainingCommand}" />
                        </Grid>
                    </Border>

                </Grid>

                <!-- Reklamlar -->
                <Border Style="{StaticResource TileCard}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AdsCommand}" />
                    </Border.GestureRecognizers>

                    <Image Source="news"
                           Aspect="AspectFill"/>
                </Border>

                <!-- Kampaniyalar -->
                <Border Style="{StaticResource TileCard}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CampaignsCommand}" />
                    </Border.GestureRecognizers>

                    <Image Source="Campaigns.png"
                           Aspect="AspectFill"/>
                </Border>

                <!-- bottom menu üçün biraz boşluq -->
                <BoxView HeightRequest="10" Opacity="0"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom menu -->
        <controls:BottomMenu Grid.Row="2"
                             VerticalOptions="End"
                             Margin="0,0,0,6"/>
    </Grid>
</ContentPage>