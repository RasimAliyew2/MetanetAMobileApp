<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MetanetA_MobileApp.View"
             x:Class="MetanetA_MobileApp.View.Gifts.GiftsPage"
             BackgroundColor="#F3F4F6"
             Title="Hədiyyələr">

    <ContentPage.Resources>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="StrokeThickness" Value="0"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 18"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow Opacity="0.12" Radius="16" Offset="0,6"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBorder" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#F9FAFB"/>
            <Setter Property="Stroke" Value="#E5E7EB"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 18"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="HeightRequest" Value="44"/>
        </Style>

    </ContentPage.Resources>

    <Grid Padding="18" RowDefinitions="Auto,*,Auto" RowSpacing="12">

        <!-- Header + Search -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="14,12">
            <VerticalStackLayout Spacing="10">

                <Label Text="Hədiyyələr"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#111827"/>

                <Border Style="{StaticResource SearchBorder}">
                    <SearchBar Placeholder="Axtarış..."
                               Text="{Binding SearchText}"
                               BackgroundColor="Transparent"
                               TextColor="#111827"
                               PlaceholderColor="#9CA3AF"
                               CancelButtonColor="#6B7280"
                               HeightRequest="44"/>
                </Border>

            </VerticalStackLayout>
        </Border>

        <!-- List -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Gifts}"
                        SelectedItem="{Binding SelectedGift, Mode=TwoWay}"
                        SelectionMode="Single">

            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10"
                            Margin="6"
                            BackgroundColor="White"
                            Stroke="#E5E7EB"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="6">
                            <Image Source="{Binding ImageUrl}"
                                   HeightRequest="90"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"/>

                            <Label Text="{Binding Name}"
                                   FontAttributes="Bold"
                                   FontSize="14"
                                   TextColor="#111827"
                                   HorizontalTextAlignment="Center"/>

                            <Label Text="{Binding Price, StringFormat='{0} Bonus'}"
                                   FontSize="13"
                                   TextColor="#6B7280"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Bottom menu -->
        <controls:BottomMenu Grid.Row="2"
                             VerticalOptions="End"
                             Margin="0,0,0,6"/>
    </Grid>
</ContentPage>
