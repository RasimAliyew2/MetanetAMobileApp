<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ViewModel="clr-namespace:MetanetA_MobileApp.ViewModels"
             x:Class="MetanetA_MobileApp.View.Gifts.GiftsPage">



    <!-- CollectionView özü scroll edir, ona görə ayrıca ScrollView lazım deyil -->
    <CollectionView
        ItemsSource="{Binding Gifts}"
        SelectionMode="Single"
        SelectedItem="{Binding SelectedGift, Mode=TwoWay}"
        Margin="16">
      

        <!-- 2 sütunlu grid layout (kart kart görünmək üçün) -->
        <CollectionView.ItemsLayout>
            <GridItemsLayout Orientation="Vertical" Span="2" />
        </CollectionView.ItemsLayout>

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border
            Padding="8"
            Margin="6"
            Stroke="#E0E0E0"
            StrokeThickness="1"
            Background="White">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>

                    <!-- Seçiləndə avtomatik "Selected" VisualState işə düşür -->
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <!-- DİQQƏT: Border-da BackgroundColor yox, Background var -->
                                    <Setter Property="Background" Value="#EEF0FF" />
                                    <Setter Property="Stroke" Value="#4C4CFF" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>

                    <VerticalStackLayout Spacing="4"
                                 HorizontalOptions="Fill"
                                 VerticalOptions="Center">

                        <Image Source="{Binding ImageUrl}"
                       HeightRequest="80"
                       Aspect="AspectFit"
                       HorizontalOptions="Center" />

                        <Label Text="{Binding Name}"
                       FontAttributes="Bold"
                       FontSize="14"
                       HorizontalOptions="Center" />

                        <Label Text="{Binding Price, StringFormat=' {0} ₼'}"
                       FontSize="13"
                       TextColor="Gray"
                       HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>
</ContentPage>