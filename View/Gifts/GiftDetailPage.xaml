<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MetanetA_MobileApp.View"
    x:Class="MetanetA_MobileApp.View.Gifts.GiftDetailPage"
    Title=""
    BackgroundColor="#F3F4F6">

    <ContentPage.Resources>

        <Style x:Key="PageCardStyle" TargetType="Border">
            <Setter Property="BackgroundColor" Value="White" />
            <Setter Property="Stroke" Value="#E5E7EB" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow Opacity="0.08" Radius="14" Offset="0,4" />
                </Setter.Value>
            </Setter>
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="22" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#16A34A" />
            <Setter Property="TextColor" Value="White" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="HeightRequest" Value="52" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="White" />
            <Setter Property="TextColor" Value="#111827" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="HeightRequest" Value="52" />
            <Setter Property="BorderColor" Value="#D1D5DB" />
            <Setter Property="BorderWidth" Value="1" />
        </Style>

    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto" Padding="18">

        <!-- Content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="14">

                <!-- Main card -->
                <Border Style="{StaticResource PageCardStyle}">
                    <VerticalStackLayout Spacing="18">

                        <!-- Image area -->
                        <Border
                            BackgroundColor="#F9FAFB"
                            Stroke="#E5E7EB"
                            StrokeThickness="1"
                            Padding="18"
                            HorizontalOptions="Fill">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>

                            <Image Source="{Binding Gift.ImageUrl}"
                                   HeightRequest="210"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Name -->
                        <Label Text="{Binding Gift.Name}"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />

                        <!-- Price badge -->
                        <Border
                            BackgroundColor="#ECFDF5"
                            Stroke="#BBF7D0"
                            StrokeThickness="1"
                            Padding="14,8"
                            HorizontalOptions="Center">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="999" />
                            </Border.StrokeShape>

                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding Gift.Price}"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#15803D"
                                       VerticalTextAlignment="Center" />
                                <Label Text="bonus"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#166534"
                                       VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- Description card -->
                <Border Style="{StaticResource PageCardStyle}">
                    <VerticalStackLayout Spacing="10">

                        <Label Text="Məhsul haqqında"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <BoxView HeightRequest="1"
                                 Color="#E5E7EB" />

                        <Label Text="{Binding Description}"
                               FontSize="15"
                               TextColor="#374151"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Warning -->
                <Border
                    IsVisible="{Binding IsVisible}"
                    BackgroundColor="#FEF2F2"
                    Stroke="#FECACA"
                    StrokeThickness="1"
                    Padding="14">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="⚠"
                               FontSize="18"
                               VerticalTextAlignment="Center" />
                        <Label Text="Hesabınızda yetərincə bonus yoxdur"
                               FontSize="14"
                               TextColor="#B91C1C"
                               VerticalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                    </HorizontalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom buttons -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,*"
              ColumnSpacing="12"
              Margin="0,14,0,0">

            <Button Text="Ləğv et"
                    Grid.Column="0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding DeclineCommand}" />

            <Button Text="Al"
                    Grid.Column="1"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding BuyCommand}" />
        </Grid>

    </Grid>
</ContentPage>