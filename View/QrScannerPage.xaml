<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MetanetA_MobileApp.View.QrScannerPage"
             Title=""
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             xmlns:zm="clr-namespace:ZXing.Net.Maui;assembly=ZXing.Net.MAUI"
             xmlns:conv="clr-namespace:MetanetA_MobileApp.Converters">

    <ContentPage.Resources>
        <!-- Converters/FirstBarcodeValueConverter.cs dosyandaki converter -->
        <conv:FirstBarcodeValueConverter x:Key="FirstBarcodeValueConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto" RowSpacing="12" Padding="16">

        <!-- KAMERA + TARAYICI -->
        <zxing:CameraBarcodeReaderView x:Name="Scanner" Grid.Row="0">

            <!-- 0.4.0 sürümünde BarcodeReaderOptions 'ZXing.Net.Maui' (zm:) içindedir -->
            <zxing:CameraBarcodeReaderView.Options>
                <zm:BarcodeReaderOptions
                    Formats="QrCode"
                    AutoRotate="True"
                    Multiple="False" />
            </zxing:CameraBarcodeReaderView.Options>

            <!-- Okunan kodu VM'deki komuta yönlendir -->
            <zxing:CameraBarcodeReaderView.Behaviors>
                <toolkit:EventToCommandBehavior
                    EventName="BarcodesDetected"
                    Command="{Binding QrDetectedCommand}"
                    EventArgsConverter="{StaticResource FirstBarcodeValueConverter}" />
            </zxing:CameraBarcodeReaderView.Behaviors>

        </zxing:CameraBarcodeReaderView>

        <!-- (İsteğe bağlı) Son okunan değeri göster -->
        <Label Grid.Row="1"
               Text="{Binding ScannedValue, StringFormat='QR: {0}'}"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center" />
    </Grid>
</ContentPage>