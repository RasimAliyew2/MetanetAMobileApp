<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:MetanetA_MobileApp.Model"
             x:Class="MetanetA_MobileApp.View.FaqPage"
             Title=""
             BackgroundColor="#F6F7FB">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label
                Text="Tez-tez verilən suallar"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="#1F2937" />

            <Label
                Text="Aşağıdakı suallara toxunaraq cavabları görə bilərsiniz."
                FontSize="14"
                TextColor="#6B7280" />

            <CollectionView
                ItemsSource="{Binding Questions}"
                SelectionMode="None">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:FaqItem">
                        <Frame
                            Margin="0,0,0,10"
                            Padding="0"
                            CornerRadius="16"
                            HasShadow="True"
                            BackgroundColor="White"
                            BorderColor="#E5E7EB">

                            <VerticalStackLayout Spacing="0">

                                <Grid Padding="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>

                                    <Label
                                        Grid.Column="0"
                                        Text="{Binding Question}"
                                        FontSize="16"
                                        FontAttributes="Bold"
                                        TextColor="#111827"
                                        VerticalOptions="Center" />

                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding ToggleText}"
                                        FontSize="22"
                                        TextColor="#2563EB"
                                        VerticalOptions="Center"
                                        HorizontalOptions="End" />
                                </Grid>

                                <VerticalStackLayout
                                    Padding="16,0,16,16"
                                    IsVisible="{Binding IsExpanded}">
                                    <Label
                                        Text="{Binding Answer}"
                                        FontSize="14"
                                        TextColor="#4B5563"
                                        LineBreakMode="WordWrap" />
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>