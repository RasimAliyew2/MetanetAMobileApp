<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MetanetA_MobileApp.View.BottomMenu"
             HeightRequest="70"
             BackgroundColor="White">

    <ContentView.Resources>
        <!-- Whole menu cell: this makes the clickable area much bigger than the icon itself. -->
        <Style x:Key="BottomMenuItem" TargetType="Grid">
            <Setter Property="Padding" Value="0,5" />
            <Setter Property="MinimumHeightRequest" Value="58" />
            <Setter Property="HorizontalOptions" Value="Fill" />
            <Setter Property="VerticalOptions" Value="Fill" />
        </Style>

        <Style x:Key="BottomMenuIcon" TargetType="Image">
            <Setter Property="WidthRequest" Value="28" />
            <Setter Property="HeightRequest" Value="28" />
            <Setter Property="Aspect" Value="AspectFit" />
            <Setter Property="InputTransparent" Value="True" />
        </Style>

        <Style x:Key="BottomMenuText" TargetType="Label">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="TextColor" Value="Black" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
            <Setter Property="InputTransparent" Value="True" />
        </Style>

        <!-- Transparent full-cell button. It sits above the icon and label. -->
        <Style x:Key="BottomMenuTapButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="Text" Value="" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderWidth" Value="0" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="HorizontalOptions" Value="Fill" />
            <Setter Property="VerticalOptions" Value="Fill" />
            <Setter Property="MinimumHeightRequest" Value="58" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Scale" Value="0.96" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentView.Resources>

    <Border StrokeThickness="0"
            BackgroundColor="White">
        <Grid ColumnDefinitions="*,*,*,*,*"
              Padding="10,6"
              ColumnSpacing="0"
              VerticalOptions="Fill">

            <!-- Home -->
            <Grid Grid.Column="0" Style="{StaticResource BottomMenuItem}">
                <VerticalStackLayout Spacing="2"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     InputTransparent="True">
                    <Image Source="house_button.png"
                           Style="{StaticResource BottomMenuIcon}">
                        <Image.Triggers>
                            <DataTrigger TargetType="Image"
                                         Binding="{Binding MenuState.IsHomeSelected}"
                                         Value="True">
                                <Setter Property="Source" Value="house_button_green" />
                            </DataTrigger>
                        </Image.Triggers>
                    </Image>

                    <Label Text="Əsas"
                           Style="{StaticResource BottomMenuText}" />
                </VerticalStackLayout>

                <Button Style="{StaticResource BottomMenuTapButton}"
                        Command="{Binding HomeCommand}" />
            </Grid>

            <!-- Products -->
            <Grid Grid.Column="1" Style="{StaticResource BottomMenuItem}">
                <VerticalStackLayout Spacing="2"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     InputTransparent="True">
                    <Image Source="products.png"
                           Style="{StaticResource BottomMenuIcon}">
                        <Image.Triggers>
                            <DataTrigger TargetType="Image"
                                         Binding="{Binding MenuState.IsProductsSelected}"
                                         Value="True">
                                <Setter Property="Source" Value="products_green.png" />
                            </DataTrigger>
                        </Image.Triggers>
                    </Image>

                    <Label Text="Məhsullar"
                           Style="{StaticResource BottomMenuText}" />
                </VerticalStackLayout>

                <Button Style="{StaticResource BottomMenuTapButton}"
                        Command="{Binding ProductsCommand}" />
            </Grid>

            <!-- QR -->
            <Grid Grid.Column="2" Style="{StaticResource BottomMenuItem}">
                <VerticalStackLayout Spacing="2"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     InputTransparent="True">
                    <Image Source="qr_code.png"
                           Style="{StaticResource BottomMenuIcon}">
                        <Image.Triggers>
                            <DataTrigger TargetType="Image"
                                         Binding="{Binding MenuState.IsQrSelected}"
                                         Value="True">
                                <Setter Property="Source" Value="qr_code_green.png" />
                            </DataTrigger>
                        </Image.Triggers>
                    </Image>

                    <Label Text="QR"
                           Style="{StaticResource BottomMenuText}" />
                </VerticalStackLayout>

                <Button Style="{StaticResource BottomMenuTapButton}"
                        Command="{Binding QrCommand}" />
            </Grid>

            <!-- Profile -->
            <Grid Grid.Column="3" Style="{StaticResource BottomMenuItem}">
                <VerticalStackLayout Spacing="2"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     InputTransparent="True">
                    <Image Source="profile.png"
                           Style="{StaticResource BottomMenuIcon}">
                        <Image.Triggers>
                            <DataTrigger TargetType="Image"
                                         Binding="{Binding MenuState.IsProfileSelected}"
                                         Value="True">
                                <Setter Property="Source" Value="profile_green.png" />
                            </DataTrigger>
                        </Image.Triggers>
                    </Image>

                    <Label Text="Profil"
                           Style="{StaticResource BottomMenuText}" />
                </VerticalStackLayout>

                <Button Style="{StaticResource BottomMenuTapButton}"
                        Command="{Binding ProfileCommand}" />
            </Grid>

            <!-- Other -->
            <Grid Grid.Column="4" Style="{StaticResource BottomMenuItem}">
                <VerticalStackLayout Spacing="2"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     InputTransparent="True">
                    <Image Source="other_icon.png"
                           Style="{StaticResource BottomMenuIcon}">
                        <Image.Triggers>
                            <DataTrigger TargetType="Image"
                                         Binding="{Binding MenuState.IsOtherSelected}"
                                         Value="True">
                                <Setter Property="Source" Value="other_green.png" />
                            </DataTrigger>
                        </Image.Triggers>
                    </Image>

                    <Label Text="Digər"
                           Style="{StaticResource BottomMenuText}" />
                </VerticalStackLayout>

                <Button Style="{StaticResource BottomMenuTapButton}"
                        Command="{Binding OtherCommand}" />
            </Grid>

        </Grid>
    </Border>
</ContentView>
